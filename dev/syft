#!/usr/bin/env python3

import sys
import json
import pprint
import argparse
from itertools import chain
from tabulate import tabulate 

def flatten(nested):
    return list(chain.from_iterable(nested))

def load_matches(path):
    with open(sys.argv[1]) as f:
        data = json.load(f)

    return data.get("matches", [])

